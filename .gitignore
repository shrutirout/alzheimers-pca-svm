__pycache__/
*.pyc
*.pyo

# ── Jupyter checkpoints ───────────────────────────────────────────────────────
.ipynb_checkpoints/
*/.ipynb_checkpoints/

# ── Markdown files (except README) ───────────────────────────────────────────
*.md
!README.md

# ── Project abstract ──────────────────────────────────────────────────────────
*.docx

